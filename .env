# ── Server ────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
BASE_URL=http://localhost:8080

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=crm_db-v1
DB_CHARSET=utf8mb4

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRE_HOURS=24

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
